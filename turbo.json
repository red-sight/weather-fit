{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true,
      "env": [
        "TG_BOT_TOKEN",
        "OPENAI_API_KEY",
        "REDIS_URL",
        "OPENAI_MODEL",
        "OPENAI_BASE_URL"
      ]
    },
    "start": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true,
      "env": [
        "TG_BOT_TOKEN",
        "OPENAI_API_KEY",
        "REDIS_URL",
        "OPENAI_MODEL",
        "OPENAI_BASE_URL"
      ]
    }
  }
}
