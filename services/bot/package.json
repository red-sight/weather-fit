{
  "name": "@repo/bot",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "files": ["dist", "locales"],
  "scripts": {
    "dev": "node --env-file-if-exists=../../.env --import tsx/esm --watch --watch-path ../../packages src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@repo/ai": "workspace:^",
    "@repo/telegram": "workspace:*",
    "@repo/weather": "workspace:*"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "eslint": "^9.39.1",
    "tsx": "^4.19.3",
    "typescript": "5.9.2"
  }
}
