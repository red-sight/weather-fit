{
  // ESLint flat config (v9)
  "eslint.useFlatConfig": true,
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],

  // Auto-fix on save
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },

  // Format on save and paste using Prettier
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,

  // ESLint working directories for monorepo
  "eslint.workingDirectories": [
    { "pattern": "apps/*/" },
    { "pattern": "packages/*/" }
  ],

  // File nesting
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "package.json": "pnpm-lock.yaml, pnpm-workspace.yaml, .npmrc, turbo.json, .editorconfig",
    "tsconfig.json": "tsconfig.*.json",
    ".env": ".env.*, .envrc",
    ".gitignore": ".gitattributes, .prettierrc, .prettierrc.*, .prettierignore",
    "eslint.config.*": ".eslintignore"
  }
}
